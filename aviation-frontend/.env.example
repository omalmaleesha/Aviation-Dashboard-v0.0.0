# ─────────────────────────────────────────────────────────────
# Aviation Dashboard — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# All VITE_ prefixed variables are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Backend REST API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket endpoints for real-time data
VITE_WS_FLIGHTS_URL=ws://localhost:8000/ws/flights
VITE_WS_ALERTS_URL=ws://localhost:8000/ws/alerts

# Default METAR ICAO station code
VITE_DEFAULT_METAR_ICAO=VCBI
