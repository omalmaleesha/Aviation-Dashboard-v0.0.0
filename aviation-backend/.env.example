# ═══════════════════════════════════════════════════════════════════════
# SkyOps Sentinel — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./skyops_sentinel.db

# ─── Base Airport Configuration ───────────────────────────────────────
BASE_AIRPORT_NAME=JFK
BASE_AIRPORT_LAT=40.6413
BASE_AIRPORT_LNG=-73.7781

# ─── OpenSky Network API ─────────────────────────────────────────────
OPENSKY_API_URL=https://opensky-network.org/api/states/all
# Optional: OpenSky credentials for higher rate limits
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ─── Active Bounding Box ─────────────────────────────────────────────
# Options: USA, EUROPE, ASIA, or leave empty for WORLDWIDE
ACTIVE_BOUNDING_BOX=ASIA

# ─── METAR Weather Source ─────────────────────────────────────────────
AVWX_METAR_URL=https://aviationweather.gov/api/data/metar

# ─── CORS Allowed Origins (comma-separated) ──────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Polling & Broadcast Intervals (seconds) ─────────────────────────
OPENSKY_POLL_INTERVAL=60
WEBSOCKET_BROADCAST_INTERVAL=60

# ─── Fuel Analytics ──────────────────────────────────────────────────
FUEL_COST_PER_KG=1.10
CO2_PER_KG_FUEL=3.16
FUEL_ANALYTICS_INTERVAL=60

# ─── Authentication & JWT Security ───────────────────────────────────
# IMPORTANT: use a long random value in production
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_ISSUER=skyops-sentinel
JWT_AUDIENCE=skyops-api
AUTH_MIN_PASSWORD_LENGTH=12

# ─── Development Seed Test User (disable in production) ──────────────
ENABLE_TEST_USER=true
TEST_USER_EMAIL=test.user@skyops.com
TEST_USER_PASSWORD=TestUser#2026!Secure

# ─── Development Seed Admin User (disable in production) ─────────────
ENABLE_ADMIN_TEST_USER=true
ADMIN_TEST_EMAIL=admin.test@skyops.com
ADMIN_TEST_PASSWORD=Admin#2026!Secure
